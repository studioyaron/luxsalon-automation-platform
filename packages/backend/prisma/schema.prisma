// New Models
model TrackingPixel {
  id Int @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AIDeliveryLog {
  id Int @id @default(autoincrement())
  deliveredAt DateTime @default(now())
  status String
}

model PersonaProfile {
  id Int @id @default(autoincrement())
  name String
  description String?
  createdAt DateTime @default(now())
}